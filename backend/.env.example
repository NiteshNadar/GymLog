# ── Server ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ── Database ─────────────────────────────────────────────────────────────
# Local Development: mongodb://localhost:27017/gym_log
# Production: mongodb+srv://<user>:<pass>@cluster.mongodb.net/gym_log
MONGODB_URI=mongodb://localhost:27017/gym_log

# ── JWT ───────────────────────────────────────────────────────────────────
# Generate via terminal command: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_hex_access_secret_here_at_least_32_characters
JWT_REFRESH_SECRET=replace_with_64_char_hex_refresh_secret_here_at_least_32_characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend URL ──────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── CORS Origins ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no spaces)
CORS_ORIGINS=http://localhost:5173

# ── Encryption (for storing sensitive third-party tokens) ────────────
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_char_hex

# ── Monitoring ────────────────────────────────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn_here
